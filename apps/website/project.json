{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/website/src",
  "targets": {
    "build": {
      "command": "pnpx astro build",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "cwd": "apps/website"
      }
    },
    "dev": {
      "command": "pnpx astro dev",
      "options": {
        "cwd": "apps/website"
      }
    },
    "serve": {
      "command": "pnpx astro preview",
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/website"
      }
    }
  },
  "tags": []
}
